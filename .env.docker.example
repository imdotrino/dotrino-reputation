# Copiá a `.env` y completá. Lo lee docker-compose.yml.

# Tu dominio para el nodo (debe apuntar A/AAAA a este host; 80/443 abiertos).
REP_DOMAIN=reputation.tudominio.com

# Contraseña fuerte de la base. Generá una:  openssl rand -hex 24
REP_DB_PASSWORD=cambiame

# Opcionales (rate limit por IP, defaults razonables):
REP_RL_READ_PER_MIN=600
REP_RL_WRITE_PER_MIN=120

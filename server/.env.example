# Puerto HTTP (independiente de geo, que usa 8090)
PORT=8091

# Conexión Postgres — base PROPIA del servicio de reputación (no compartir con geo).
DATABASE_URL=postgres://reputation:reputation@localhost:5432/reputation

# Tolerancia de reloj para anti-replay del sobre firmado (ms).
REP_CLOCK_SKEW_MS=300000

# Rate limit por IP (generoso; token bucket). capacity por minuto por IP.
REP_RL_READ_PER_MIN=600
REP_RL_WRITE_PER_MIN=120
# REP_RL_DISABLED=1   # desactivar el rate limit
# REP_TRUST_PROXY=0   # si se expone SIN nginx delante
